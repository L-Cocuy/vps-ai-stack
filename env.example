# ============================================================
#  VPS AI Stack — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to git.
# ============================================================

# Your domain (e.g. mycompany.com)
# Services will be available at:
#   chat.yourdomain.com       → Private AI chat
#   automation.yourdomain.com → Workflow automation
DOMAIN=yourdomain.com

# Postgres credentials — change these before deploying!
POSTGRES_DB=ai_stack
POSTGRES_USER=ai_admin
POSTGRES_PASSWORD=change_me_strong_password

# Open WebUI — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change_me

# n8n — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me

# Set to "true" to allow new users to register
ENABLE_SIGNUP=false

# Email for Let's Encrypt SSL certificate
ACME_EMAIL=you@yourdomain.com
