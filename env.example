# VPS AI Stack environment file
# Copy to .env, set real values, and keep it out of git.

# Apex domain only, for example: example.com
DOMAIN=yourdomain.com

# Postgres settings for n8n
POSTGRES_DB=ai_stack
POSTGRES_USER=ai_admin
POSTGRES_PASSWORD=change_me_strong_password

# Open WebUI secret, generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change_me

# n8n secret, generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me

# Keep signups disabled unless you intend to open registration.
ENABLE_SIGNUP=false

# Optional CIDR allowlist for the n8n UI and webhooks.
# Leave blank to allow all clients.
# Example: 203.0.113.10/32,198.51.100.0/24
N8N_IP_ALLOWLIST=

# Real email for Let's Encrypt expiry notices
ACME_EMAIL=you@yourdomain.com

# Optional but recommended for logs and workflow timestamps
GENERIC_TIMEZONE=UTC

# Optional health-report thresholds
HEALTH_DISK_WARN_PCT=85
HEALTH_DISK_FAIL_PCT=95

# Optional encrypted offsite backups.
# Local backups still run even if remote mode is disabled or misconfigured.
BACKUP_REMOTE_ENABLED=false
BACKUP_REMOTE_TYPE=
BACKUP_PASSPHRASE=

# S3-compatible remote target
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=vps-ai-stack
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# Backblaze B2 S3-compatible target
BACKUP_B2_BUCKET=
BACKUP_B2_PREFIX=vps-ai-stack
BACKUP_B2_REGION=us-west-002
BACKUP_B2_ENDPOINT=
BACKUP_B2_KEY_ID=
BACKUP_B2_APPLICATION_KEY=

# rsync target over SSH
BACKUP_RSYNC_TARGET=
BACKUP_RSYNC_SSH_KEY=
BACKUP_RSYNC_SSH_OPTS=
